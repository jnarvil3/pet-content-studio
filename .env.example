# API Keys
# OpenAI for content generation
OPENAI_API_KEY=your_openai_api_key_here

# Optional: ElevenLabs for TTS (Level 2 - better quality)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Pexels for stock footage (Level 2)
PEXELS_API_KEY=your_pexels_api_key_here

# Database - link to intelligence collector
INTEL_DATABASE_PATH=../pet-intel-collector/data/signals.db

# Output directories
OUTPUT_DIR=./output
CAROUSEL_OUTPUT=./output/carousels
REEL_OUTPUT=./output/reels
SCRIPT_OUTPUT=./output/scripts

# Server
PORT=3001
NODE_ENV=development

# Brand Configuration
BRAND_NAME=SureStep Automation
BRAND_HANDLE=@surestepautomation
BRAND_PRIMARY_COLOR=#667eea
BRAND_SECONDARY_COLOR=#764ba2
BRAND_LOGO_PATH=./config/logo.png
