# API Keys (required)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic (Claude) for content generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: ElevenLabs for TTS (Level 2 - Reels)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Pexels for stock photos/videos
PEXELS_API_KEY=your_pexels_api_key_here

# Optional: YouTube for viral video collection
YOUTUBE_API_KEY=your_youtube_api_key_here

# Database paths (Railway volume mount)
INTEL_DATABASE_PATH=./data/signals.db
VIRAL_DATABASE_PATH=./data/viral-signals.db

# Server
PORT=3001
NODE_ENV=production

# Optional: Dashboard authentication
AUTH_PASSWORD=

# Brand Configuration
BRAND_NAME=SureStep Automation
BRAND_HANDLE=@surestepautomation
BRAND_PRIMARY_COLOR=#667eea
BRAND_SECONDARY_COLOR=#764ba2
BRAND_LOGO_PATH=./config/logo.png

# Output directories
OUTPUT_DIR=./output
CAROUSEL_OUTPUT=./output/carousels
REEL_OUTPUT=./output/reels
SCRIPT_OUTPUT=./output/scripts
