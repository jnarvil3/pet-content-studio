{
  "name": "pet-content-generator",
  "version": "1.0.0",
  "description": "Automated Instagram content generator for pet industry - Level 1: Carousels, Level 2: Reels",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "generate": "tsx src/cli/generate-carousels.ts",
    "generate:batch": "tsx src/cli/generate-carousels.ts 10 70",
    "test": "tsx src/test.ts"
  },
  "keywords": [
    "instagram",
    "content",
    "automation",
    "carousel",
    "reels",
    "pet"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@remotion/bundler": "^4.0.294",
    "@remotion/renderer": "^4.0.294",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "openai": "^4.104.0",
    "puppeteer": "^23.11.0",
    "react": "^19.0.0",
    "remotion": "^4.0.294"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
